
@model LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<style>
    body {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI', sans-serif;
        color: #fff;
    }

    .login-card {
        width: 400px;
        background: rgba(30, 30, 47, 0.95);
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.6);
        backdrop-filter: blur(10px);
        text-align: center;
    }

    .logo {
        width: 120px;
        margin-bottom: 15px;
    }

    .brand {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: 2px;
        margin-bottom: 25px;
    }

    .form-control {
        background-color: #2c2f33;
        border: 1px solid #444;
        color: #fff;
        border-radius: 10px;
        padding: 10px;
    }

        .form-control:focus {
            background-color: #2c2f33;
            border-color: #0d6efd;
            box-shadow: none;
            color: #fff;
        }

    .btn-login {
        background: linear-gradient(135deg, #0d6efd, #1e40af);
        border: none;
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13,110,253,0.4);
        }

    .form-label {
        float: left;
        margin-bottom: 5px;
        font-size: 0.9rem;
        color: #adb5bd;
    }

    .text-danger {
        font-size: 0.85rem;
    }
</style>

<div class="login-card">

    <!-- LOGO -->
    <img src="~/images/Logo.jpg" class="logo" />

    <div class="brand">MODERNBNB</div>

    <form asp-action="Login" method="post" enctype="multipart/form-data">

        <div class="mb-3 text-start">
            <label class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="Enter your email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3 text-start">
            <label class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-login w-100">
            <i class="bi bi-box-arrow-in-right"></i> Login
        </button>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}