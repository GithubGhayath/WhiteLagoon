@model Amenity

@{
    ViewData["Title"] = "Delete Amenity";
}

<style>
    .delete-container {
        margin-top: 60px;
        max-width: 650px;
        background-color: #212529;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.6);
        color: #f8f9fa;
        text-align: center;
    }

    .warning-icon {
        font-size: 50px;
        color: #dc3545;
        margin-bottom: 15px;
    }

    .delete-title {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .delete-subtitle {
        color: #adb5bd;
        margin-bottom: 25px;
    }

    .info-box {
        background-color: #343a40;
        padding: 20px;
        border-radius: 10px;
        text-align: left;
        margin-bottom: 25px;
    }

    .info-label {
        font-weight: 600;
        color: #ced4da;
    }

    .info-value {
        color: #f8f9fa;
        margin-bottom: 10px;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

        .btn-delete:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #bb2d3b, #842029);
        }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 8px;
        margin-left: 10px;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background-color: #5a6268;
            transform: translateY(-2px);
        }
</style>

<div class="container delete-container">

    <div class="warning-icon">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h3 class="delete-title">Delete Amenity</h3>
    <p class="delete-subtitle">
        Are you sure you want to delete this amenity? This action cannot be undone.
    </p>

    <!-- Amenity Details -->
    <div class="info-box">

        <div class="info-label"><strong>Name:</strong></div>
        <div class="info-value">@Model.Name</div>

        <div class="info-label"><strong>Description:</strong></div>
        <div class="info-value">@Model.Description</div>

        <div class="info-label"><strong>Villa:</strong></div>
        <div class="info-value">
            @(Model.Villa != null ? Model.Villa.Name : "N/A")
        </div>

    </div>

    <!-- Form -->
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-delete">
            <i class="bi bi-trash"></i> Yes, Delete
        </button>

        <a asp-action="Index" class="btn btn-cancel">
            Cancel
        </a>
    </form>

</div>