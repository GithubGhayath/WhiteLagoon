@model Status

@{
    ViewData["Title"] = "Edit Status";
}

<div class="container mt-4 text-light">

    <h2 class="mb-4">
        <i class="bi bi-pencil-square"></i> Edit Status
    </h2>

    <form asp-action="Edit" method="post" class="bg-dark p-4 rounded shadow">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control bg-secondary text-light border-0" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control bg-secondary text-light border-0"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Update
        </button>

        <a asp-action="Index" class="btn btn-secondary">Cancel</a>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}