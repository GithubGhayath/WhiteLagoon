@model IEnumerable<Villa>

@{
    ViewData["Title"] = "Villa List";
}

<style>
    .villa-container {
        margin-top: 40px;
    }

    .villa-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .villa-title {
        font-weight: 700;
        color: #2c3e50;
    }

    .btn-add {
        background: linear-gradient(135deg, #28a745, #218838);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

        .btn-add:hover {
            background: linear-gradient(135deg, #218838, #1e7e34);
            transform: translateY(-2px);
        }

    .table-custom {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

        .table-custom thead {
            background: linear-gradient(135deg, #343a40, #212529);
            color: white;
            text-transform: uppercase;
            font-size: 14px;
        }

        .table-custom tbody tr {
            transition: 0.2s;
        }

            .table-custom tbody tr:hover {
                background-color: #f8f9fa;
                transform: scale(1.01);
            }

    .price {
        color: #28a745;
        font-weight: 600;
    }

    .badge-occupancy {
        background-color: #007bff;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

    .empty-state {
        margin-top: 20px;
        text-align: center;
    }

    .btn-action {
        margin-right: 5px;
        padding: 5px 12px;
        font-size: 14px;
        border-radius: 6px;
        transition: 0.2s;
    }

    .btn-update {
        background-color: #ffc107;
        color: #212529;
        border: none;
    }

        .btn-update:hover {
            background-color: #e0a800;
            transform: translateY(-1px);
        }

    .btn-delete {
        background-color: #dc3545;
        color: white;
        border: none;
    }

        .btn-delete:hover {
            background-color: #c82333;
            transform: translateY(-1px);
        }
</style>

<div class="container villa-container">
    <div class="villa-header">
        <h2 class="villa-title">🏝️ Villa List</h2>

        <a asp-controller="Villa" asp-action="Create" class="btn btn-add">
            <i class="bi bi-plus-circle"></i> Add New Villa
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning empty-state">
            No villas available at the moment.
        </div>
    }
    else
    {
        <table class="table table-hover table-custom">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Sqft</th>
                    <th>Occupancy</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var villa in Model)
                {
                    <tr>
                        <td>@villa.Id</td>
                        <td>@villa.Name</td>
                        <td class="price">@villa.Price.ToString("C")</td>
                        <td>@villa.Sqft</td>
                        <td>
                            <span class="badge-occupancy">
                                @villa.Occupancy persons
                            </span>
                        </td>
                        <td>
                            <a asp-controller="Villa" asp-action="Edit" asp-route-id="@villa.Id" class="btn btn-action btn-update">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-controller="Villa" asp-action="Delete" asp-route-id="@villa.Id" class="btn btn-action btn-delete">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>