@model PaymentMethod

@{
    ViewData["Title"] = "Edit Payment Method";
}

<style>
    .edit-container {
        margin-top: 40px;
        max-width: 700px;
        background-color: #1e1e2f;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
        color: #f8f9fa;
    }

    .form-label {
        font-weight: 600;
        color: #e0e0e0;
    }

    .form-control {
        background-color: #2c2f33;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 5px;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: none;
        }

    .field-validation {
        display: block;
        min-height: 1.25em;
        margin-bottom: 10px;
        color: #ff6b6b;
        font-size: 0.85rem;
    }

    .btn-update {
        background: linear-gradient(135deg, #0d6efd, #0056b3);
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
    }

        .btn-update:hover {
            transform: translateY(-2px);
        }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        margin-left: 10px;
        text-decoration: none;
    }
</style>

<div class="container edit-container">

    <h2 class="mb-4">
        <i class="bi bi-pencil-square"></i> Edit Payment Method
    </h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="field-validation"></div>

        <!-- Method -->
        <label asp-for="Method" class="form-label"></label>
        <input asp-for="Method" class="form-control" />
        <span asp-validation-for="Method" class="field-validation"></span>

        <!-- Description -->
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="field-validation"></span>

        <!-- Buttons -->
        <div class="mt-4">
            <button type="submit" class="btn btn-update">
                <i class="bi bi-save"></i> Update
            </button>

            <a asp-action="Index" class="btn-cancel">
                Cancel
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}