@model User

@{
    ViewData["Title"] = "Edit User";
}

<style>
    .edit-container {
        margin-top: 40px;
        max-width: 700px;
        background-color: #1e1e2f;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
        color: #f8f9fa;
    }

    .form-label {
        font-weight: 600;
        color: #e0e0e0;
    }

    .form-control {
        background-color: #2c2f33;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 5px;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: none;
            color: #fff;
        }

    .field-validation {
        display: block;
        min-height: 1.25em;
        margin-bottom: 10px;
        color: #ff6b6b;
        font-size: 0.85rem;
    }

    .btn-update {
        background: linear-gradient(135deg, #0d6efd, #0056b3);
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
    }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        margin-left: 10px;
        text-decoration: none;
    }

    .password-note {
        font-size: 0.85rem;
        color: #adb5bd;
        margin-bottom: 10px;
    }
</style>

<div class="container edit-container">

    <h2 class="mb-4">
        <i class="bi bi-person-gear"></i> Edit User
    </h2>

    <form asp-action="Edit" method="post">

        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="field-validation"></div>

        <!-- Username -->
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="field-validation"></span>

        <!-- Password (optional update) -->
        <label class="form-label">New Password</label>
        <input name="Password" type="password" class="form-control" placeholder="Leave empty to keep current password" />
        <div class="password-note">Leave empty if you don’t want to change the password.</div>

        <!-- Full Name -->
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="field-validation"></span>

        <!-- Email -->
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" type="email" class="form-control" />
        <span asp-validation-for="Email" class="field-validation"></span>

        <!-- Phone -->
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="field-validation"></span>

        <!-- Status -->
        <div class="form-check mt-3">
            <input asp-for="IsDeleted" class="form-check-input" />
            <label asp-for="IsDeleted" class="form-check-label">
                Mark as Deleted (Deactivate User)
            </label>
        </div>

        <!-- Buttons -->
        <div class="mt-4">
            <button type="submit" class="btn btn-update">
                <i class="bi bi-save"></i> Update
            </button>

            <a asp-action="Index" class="btn-cancel">
                Cancel
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}