@model PaymentMethod

@{
    ViewData["Title"] = "Delete Payment Method";
}

<style>
    .delete-container {
        margin-top: 60px;
        max-width: 600px;
        background-color: #1e1e2f;
        padding: 30px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 6px 20px rgba(0,0,0,0.6);
        color: #f8f9fa;
    }

    .warning-icon {
        font-size: 50px;
        color: #dc3545;
        margin-bottom: 15px;
    }

    .info-box {
        background-color: #2c2f33;
        padding: 20px;
        border-radius: 10px;
        text-align: left;
        margin-bottom: 20px;
    }

    .info-label {
        font-weight: 600;
        color: #adb5bd;
    }

    .info-value {
        margin-bottom: 10px;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
        border: none;
        color: white;
        padding: 10px 25px;
        border-radius: 8px;
    }

        .btn-delete:hover {
            transform: translateY(-2px);
        }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        padding: 10px 25px;
        border-radius: 8px;
        margin-left: 10px;
        text-decoration: none;
    }
</style>

<div class="container delete-container">

    <div class="warning-icon">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h3>Delete Payment Method</h3>
    <p class="text-muted">
        Are you sure you want to delete this method? This action cannot be undone.
    </p>

    <!-- Info -->
    <div class="info-box">
        <div class="info-label">Method</div>
        <div class="info-value">@Model.Method</div>

        <div class="info-label">Description</div>
        <div class="info-value">@Model.Description</div>
    </div>

    <!-- Form -->
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-delete">
            <i class="bi bi-trash"></i> Delete
        </button>

        <a asp-action="Index" class="btn-cancel">
            Cancel
        </a>
    </form>

</div>