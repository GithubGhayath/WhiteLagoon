@model User

@{
    ViewData["Title"] = "Delete User";
}

<style>
    .delete-container {
        margin-top: 40px;
        max-width: 700px;
        background-color: #1e1e2f;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
        color: #f8f9fa;
    }

    .delete-header {
        margin-bottom: 20px;
    }

    .delete-title {
        font-weight: 700;
        color: #ff6b6b;
    }

    .delete-warning {
        background-color: #2c2f33;
        border-left: 5px solid #dc3545;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        color: #f8d7da;
    }

    .user-info {
        background-color: #343a40;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 25px;
    }

        .user-info p {
            margin: 5px 0;
        }

    .label {
        font-weight: 600;
        color: #adb5bd;
    }

    .value {
        color: #f8f9fa;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 500;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: linear-gradient(135deg, #a71d2a, #7f1320);
            transform: translateY(-2px);
        }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        margin-left: 10px;
        transition: 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-cancel:hover {
            background-color: #5a6268;
            transform: translateY(-2px);
        }
</style>

<div class="container delete-container">
    <div class="delete-header">
        <h2 class="delete-title">
            <i class="bi bi-exclamation-triangle"></i> Delete User
        </h2>
    </div>

    <div class="delete-warning">
        ⚠️ Are you sure you want to delete this user? This action cannot be undone.
    </div>

    <div class="user-info">
        <p><span class="label">Username:</span> <span class="value">@Model.UserName</span></p>
        <p><span class="label">Full Name:</span> <span class="value">@Model.FullName</span></p>
        <p><span class="label">Email:</span> <span class="value">@Model.Email</span></p>
        <p><span class="label">Phone Number:</span> <span class="value">@Model.PhoneNumber</span></p>
        <p><span class="label">Status:</span> <span class="value">@((Model.IsDeleted) ? "Deleted" : "Active")</span></p>
        <p><span class="label">Created At:</span> <span class="value">@Model.CreatedAt?.ToString("g")</span></p>
        <p><span class="label">Updated At:</span> <span class="value">@Model.UpdatedAt?.ToString("g")</span></p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-delete">
            <i class="bi bi-trash"></i> Confirm Delete
        </button>

        <a asp-action="Index" class="btn-cancel">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </form>
</div>