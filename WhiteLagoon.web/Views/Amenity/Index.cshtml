@model IEnumerable<Amenity>

@{
    ViewData["Title"] = "Amenities";
}

<style>
    body {
        background-color: #121212;
        color: #e0e0e0;
    }

    .container-box {
        margin-top: 50px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .title {
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 0.5px;
    }

    .btn-create {
        background: linear-gradient(135deg, #198754, #146c43);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 500;
        transition: 0.3s;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }

        .btn-create:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #157347, #0f5132);
        }

    .table-container {
        background: #1e1e2f;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    }

    table {
        width: 100%;
        color: #f8f9fa;
    }

    th {
        color: #adb5bd;
        font-weight: 600;
        border-bottom: 1px solid #444;
        padding-bottom: 12px;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    td {
        padding: 14px 0;
        border-bottom: 1px solid #2c2f33;
        vertical-align: middle;
    }

    tr:hover {
        background-color: rgba(255,255,255,0.03);
        transition: 0.2s;
    }

    .villa-badge {
        background-color: #0d6efd;
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .btn-action {
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
        margin-right: 5px;
        color: white;
        transition: 0.3s;
        box-shadow: 0 3px 8px rgba(0,0,0,0.3);
    }

    .btn-edit {
        background: linear-gradient(135deg, #0d6efd, #084298);
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545, #a71d2a);
    }

    .btn-action:hover {
        transform: translateY(-2px);
        opacity: 0.9;
    }

    .no-data {
        text-align: center;
        padding: 30px;
        color: #888;
        font-style: italic;
    }
</style>

<div class="container container-box">

    <!-- Header -->
    <div class="header">
        <h2 class="title">
            <i class="bi bi-list-check"></i> Amenities
        </h2>

        <a asp-action="Create" class="btn btn-create">
            <i class="bi bi-plus-circle"></i> Add Amenity
        </a>
    </div>

    <!-- Table -->
    <div class="table-container">
        <table class="table table-borderless">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Villa</th>
                    <th style="width:150px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                            </td>

                            <td>
                                <span style="color:#cfcfcf;">
                                    @item.Description
                                </span>
                            </td>

                            <td>
                                @if (item.Villa != null)
                                {
                                    <span class="villa-badge">
                                        @item.Villa.Name
                                    </span>
                                }
                            </td>

                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-action btn-edit">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-action btn-delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="no-data">
                            🚫 No amenities found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>