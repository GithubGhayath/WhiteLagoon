@model IEnumerable<User>

@{
    ViewData["Title"] = "Users";
}

<style>
    .page-container {
        margin-top: 30px;
        color: #f8f9fa;
    }

    .table-container {
        background-color: #1e1e2f;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    }

    .table {
        color: #fff;
    }

        .table thead {
            background-color: #2c2f33;
        }

        .table th {
            border: none;
        }

        .table td {
            vertical-align: middle;
            border-color: #444;
        }

    .badge-active {
        background-color: #198754;
        padding: 6px 10px;
        border-radius: 6px;
    }

    .badge-deleted {
        background-color: #dc3545;
        padding: 6px 10px;
        border-radius: 6px;
    }

    .btn-custom {
        padding: 5px 10px;
        border-radius: 6px;
        margin-right: 5px;
    }

    .btn-edit {
        background-color: #0d6efd;
        color: white;
    }

    .btn-delete {
        background-color: #dc3545;
        color: white;
    }

    /* NEW */
    .btn-details {
        background-color: #6c757d;
        color: white;
    }

    .btn-disabled {
        pointer-events: none;
        opacity: 0.5;
    }

    .btn-create {
        margin-bottom: 15px;
        background: linear-gradient(135deg, #0d6efd, #0056b3);
        color: white;
        border-radius: 8px;
        padding: 8px 15px;
    }

        .btn-create:hover {
            transform: translateY(-2px);
        }
</style>

<div class="container page-container">

    <h2 class="mb-3">
        <i class="bi bi-people"></i> Users Management
    </h2>

    <a asp-action="Create" class="btn btn-create">
        <i class="bi bi-plus-circle"></i> Create New User
    </a>

    <div class="table-container">
        <table class="table table-hover align-middle">

            <thead>
                <tr>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning empty-state">
                    <i class="bi bi-ban"></i> No users available at the moment.
                </div>
            }
            else
            {
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>

                            <td>
                                @if (!item.IsDeleted)
                                {
                                    <span class="badge-active">Active</span>
                                }
                                else
                                {
                                    <span class="badge-deleted">Deleted</span>
                                }
                            </td>

                            <td>
                                @(item.CreatedAt?.ToString("yyyy-MM-dd") ?? "-")
                            </td>

                            <td>
                                <!-- Edit -->
                                <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-custom btn-edit @(item.IsDeleted ? "btn-disabled" : "")">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <!-- Delete -->
                                <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-custom btn-delete @(item.IsDeleted ? "btn-disabled" : "")">
                                    <i class="bi bi-trash"></i>
                                </a>

                                <!-- NEW: Details -->
                                <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-custom btn-details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>

</div>