@model User

@{
    ViewData["Title"] = "Create User";
}

<style>
    .create-container {
        margin-top: 40px;
        max-width: 700px;
        background-color: #1e1e2f;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
        color: #f8f9fa;
    }

    .form-label {
        font-weight: 600;
        color: #e0e0e0;
    }

    .form-control {
        background-color: #2c2f33;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
        padding: 10px;
        margin-bottom: 5px;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: none;
            color: #fff;
        }

    .field-validation {
        display: block;
        min-height: 1.25em;
        margin-bottom: 10px;
        color: #ff6b6b;
        font-size: 0.85rem;
    }

    .btn-save {
        background: linear-gradient(135deg, #0d6efd, #0056b3);
        border: none;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
    }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        margin-left: 10px;
        text-decoration: none;
    }
</style>

<div class="container create-container">

    <h2 class="mb-4">
        <i class="bi bi-person-plus"></i> Create User
    </h2>

    <form asp-action="Create" method="post">

        <div asp-validation-summary="ModelOnly" class="field-validation"></div>

        <!-- Username -->
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" placeholder="Enter username" />
        <span asp-validation-for="UserName" class="field-validation"></span>

        <!-- Password -->
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
        <span asp-validation-for="Password" class="field-validation"></span>

        <!-- Full Name -->
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
        <span asp-validation-for="FullName" class="field-validation"></span>

        <!-- Email -->
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" type="email" class="form-control" placeholder="Enter email" />
        <span asp-validation-for="Email" class="field-validation"></span>

        <!-- Phone -->
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
        <span asp-validation-for="PhoneNumber" class="field-validation"></span>

        <!-- Buttons -->
        <div class="mt-4">
            <button type="submit" class="btn btn-save">
                <i class="bi bi-save"></i> Save
            </button>

            <a asp-action="Index" class="btn-cancel">
                Cancel
            </a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}