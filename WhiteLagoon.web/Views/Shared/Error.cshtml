@{
    ViewData["Title"] = "Error";
}

<style>
    .error-page {
        min-height: 80vh; /* don't override full layout height */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .error-container {
        text-align: center;
        max-width: 500px;
        width: 100%;
    }

    .error-img {
        width: 100%;
        max-height: 320px;
        object-fit: contain;
        margin-bottom: 20px;
    }

    /* Adaptive text colors */
    .error-title {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--bs-body-color, #e5e7eb); /* works with Bootstrap or fallback */
    }

    .error-message {
        font-size: 16px;
        margin-bottom: 25px;
        color: var(--bs-secondary-color, #9ca3af);
    }

    .error-btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
        background-color: #4f46e5;
        color: white;
    }

    .error-btn:hover {
        background-color: #4338ca;
    }
</style>

<div class="error-page">
    <div class="error-container">

        <!-- Image -->
        <img src="~/Images/ErrorImage.jpg" class="error-img" alt="Error Image" />

        <!-- Title -->
        <div class="error-title">
            Something went wrong
        </div>

        <!-- Message -->
        <div class="error-message">
            The action you tried to perform failed. Please try again or return home.
        </div>

        <!-- Button -->
        <a asp-controller="Home" asp-action="Index" class="error-btn">
            Go Back Home
        </a>

    </div>
</div>