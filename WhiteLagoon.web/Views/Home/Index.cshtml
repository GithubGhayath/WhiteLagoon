@model HomeVM

@{
    ViewData["Title"] = "Home";
}

<style>
    body {
        background-color: #121212;
        color: #f8f9fa;
    }

    .hero {
        height: 100vh;
        background: url('/images/herocover.jpg') center/cover no-repeat;
        position: relative;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.6);
    }

    .hero-content {
        position: absolute;
        bottom: 50px;
        left: 50px;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 700;
    }

    .booking-box {
        margin-top: 10vh;
        background: #1e1e2f;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.6);
    }

    .form-control {
        background-color: #2c2f33;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
    }

        .form-control:focus {
            background-color: #2c2f33;
            color: white;
            border-color: #0d6efd;
            box-shadow: none;
        }

    .villa-card {
        background: #1e1e2f;
        border-radius: 12px;
        overflow: hidden;
        transition: 0.3s;
        box-shadow: 0 6px 15px rgba(0,0,0,0.4);
    }

        .villa-card:hover {
            transform: translateY(-5px);
        }

    .villa-img {
        height: 200px;
        object-fit: cover;
        width: 100%;
    }

    .villa-body {
        padding: 15px;
    }

    .villa-title {
        font-weight: 600;
        font-size: 1.2rem;
    }

    .villa-info {
        font-size: 0.9rem;
        color: #adb5bd;
    }

    .price {
        font-weight: bold;
        color: #0d6efd;
    }

    /* NEW (minimal safe addition) */
    .btn-book {
        border-radius: 6px;
    }
</style>

<!-- HERO -->
<div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="hero-title">Find Your Perfect Villa</h1>
        <p>Luxury stays. Best prices. Easy booking.</p>
    </div>
</div>

<!-- BOOKING -->
<div class="container">
    <div class="booking-box row align-items-end">

        <div class="col-md-4">
            <label class="form-label">
                <i class="bi bi-calendar-check"></i> Check-In
            </label>
            <input type="date" class="form-control" asp-for="CheckInDate" readonly />
        </div>

        <div class="col-md-3">
            <label class="form-label">
                <i class="bi bi-moon"></i> Nights
            </label>
            <input type="number" class="form-control" asp-for="Nights" min="1" max="30" />
        </div>

        <div class="col-md-3">
            <button class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Check Availability
            </button>
        </div>

    </div>
</div>

<!-- VILLA LIST -->
<div class="container mt-5">
    <h3 class="mb-4">
        <i class="bi bi-house-door"></i> Available Villas
    </h3>

    <div class="row g-4">

        @if (Model.VillaList != null && Model.VillaList.Any())
        {
            foreach (var villa in Model.VillaList)
            {
                var modalId = "villaModal_" + villa.Id;

                <div class="col-md-4">
                    <div class="villa-card">

                        <img src="@villa.ImageUrl" class="villa-img" />

                        <div class="villa-body">

                            <div class="villa-title">@villa.Name</div>

                            <div class="villa-info mt-2">
                                <i class="bi bi-people"></i> @villa.Occupancy Guests <br />
                                <i class="bi bi-aspect-ratio"></i> @villa.Sqft sqft
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="price">$@villa.Price / night</div>

                                <div>
                                    <!-- EXISTING VIEW BUTTON -->
                                    <button class="btn btn-sm btn-outline-light"
                                            data-bs-toggle="modal"
                                            data-bs-target="#@modalId">
                                        View
                                    </button>

                                    <!-- NEW BOOK BUTTON -->
                                    <a asp-action="Book"
                                           asp-route-id="@villa.Id"
                                           class="btn btn-sm btn-success btn-book @(villa.IsBooked ? "disabled" : "")">
                                        Book
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- MODAL -->
                <div class="modal fade" id="@modalId" tabindex="-1">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content bg-dark text-light">

                            <div class="modal-header border-secondary">
                                <h5 class="modal-title">@villa.Name</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">

                                <img src="@villa.ImageUrl" class="img-fluid rounded mb-3" />

                                <p>@villa.Description</p>

                                <hr />

                                <div class="row">
                                    <div class="col-md-4">
                                        <strong>Price:</strong> $@villa.Price
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Size:</strong> @villa.Sqft sqft
                                    </div>
                                    <div class="col-md-4">
                                        <strong>Guests:</strong> @villa.Occupancy
                                    </div>
                                </div>

                                <hr />

                                <h6>Amenities</h6>
                                <ul>
                                    @foreach (var a in villa.Amenities)
                                    {
                                        <li>@a.Name - @a.Description</li>
                                    }
                                </ul>

                                <h6>Villa Numbers</h6>
                                <ul>
                                    @foreach (var v in villa.VillaNumbers)
                                    {
                                        <li>#@v.Villa_Number - @v.SpecialDetails</li>
                                    }
                                </ul>

                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p>No villas available.</p>
        }

    </div>
</div>